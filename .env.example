# --- PostgreSQL ---
POSTGRES_USER=drawing2dxf
POSTGRES_PASSWORD=drawing2dxf
POSTGRES_DB=drawing2dxf
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DSN=postgres://drawing2dxf:drawing2dxf@postgres:5432/drawing2dxf?sslmode=disable

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=drawing2dxf
MINIO_SECRET_KEY=drawing2dxf-secret
MINIO_BUCKET=drawing2dxf
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# --- Kafka / Redpanda ---
KAFKA_BROKERS=redpanda:9092
KAFKA_CLIENT_ID=drawing2dxf
KAFKA_CONSUMER_GROUP=drawing2dxf

# --- API ---
API_HTTP_ADDR=:8080
API_PUBLIC_BASE_URL=http://localhost:8080
API_LOG_LEVEL=info
API_PORT=8080
# For external access set your real host/IP, for example:
# API_PUBLIC_BASE_URL=http://192.168.1.50:8080
# API_CORS_ALLOWED_ORIGINS=http://192.168.1.50:5173
API_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Web ---
WEB_API_BASE_URL=http://localhost:8080
WEB_PORT=5173
# For external access set API host/IP reachable from browser clients:
# WEB_API_BASE_URL=http://192.168.1.50:8080

# --- Models (paths to weight files; if missing → fallback) ---
MODEL_ROUTER_WEIGHTS=/models/yolo11s-cls/weights.pt
SEGMENTATION_WEIGHTS=/models/yolo11m-seg/weights.pt
OCR_WEIGHTS_DIR=/models/paddleocr-pp-ocrv5
VLM_WEIGHTS_DIR=/models/qwen2.5-vl
SAM_WEIGHTS=/models/sam2.1/weights.pt

# --- Runtime flags ---
ENABLE_GPU=false
DXF_DEFAULT_VERSION=R2010
DXF_FALLBACK_VERSION=R2000
DEFAULT_DPI=300

# --- Limits / safety ---
MAX_UPLOAD_BYTES=2147483648
MAX_ARCHIVE_FILES=10000
MAX_ARCHIVE_DEPTH=8
MAX_ARCHIVE_UNCOMPRESSED_BYTES=21474836480
MAX_PAGE_PIXELS=200000000

# --- Observability ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
